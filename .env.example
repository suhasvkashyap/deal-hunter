# LLM Configuration
# Provider: "ollama", "vllm", or "openai"
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=gemma3:4b
LLM_API_KEY=no-key

# Search
# Get a key at https://serpapi.com — leave empty to use mock data
SERPAPI_KEY=
USE_MOCK_DATA=true

# Storage
OUTPUT_DIR=reports
DB_PATH=price_history.db

# Retailers to search (comma-separated)
RETAILERS=amazon,costco,walmart,bestbuy
